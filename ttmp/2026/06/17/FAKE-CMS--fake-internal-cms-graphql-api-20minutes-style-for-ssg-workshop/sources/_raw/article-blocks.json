    "blocks": [
      {
        "type": "group",
        "tag": "div",
        "text_chars": 68,
        "text_preview": "Au-delà de l’audience, l’attachement des Français aux marques d’info",
        "has_image": false,
        "has_embed": false
      },
      {
        "type": "heading",
        "tag": "h3",
        "text_chars": 111,
        "text_preview": "Étude Harris Interactive pour 20 Minutes : Au-delà de l’audience, l’attachement ",
        "has_image": false,
        "has_embed": false
      },
      {
        "type": "paragraph",
        "tag": "p",
        "text_chars": 565,
        "text_preview": "Ultra puissante sur l’ensemble de ses supports, avec chaque mois près de 22,5 d’",
        "has_image": false,
        "has_embed": false
      },
      {
        "type": "paragraph",
        "tag": "p",
        "text_chars": 0,
        "text_preview": "",
        "has_image": false,
        "has_embed": false
      },
      {
        "type": "paragraph",
        "tag": "p",
        "text_chars": 59,
        "text_preview": "Etre puissant c’est bien… être préféré c’est encore mieux !",
        "has_image": false,
        "has_embed": false
      },
      {
        "type": "paragraph",
        "tag": "p",
        "text_chars": 231,
        "text_preview": "Parmi l’ensemble des Français interrogés, 32% placent 20 Minutes dans leur top 3",
        "has_image": false,
        "has_embed": false
      },
      {
        "type": "paragraph",
        "tag": "p",
        "text_chars": 108,
        "text_preview": "« Selon l’image que vous en avez, veuillez classer par ordre de préférence les m",
        "has_image": false,
        "has_embed": false
      },
      {
        "type": "paragraph",
        "tag": "p",
        "text_chars": 0,
        "text_preview": "",
        "has_image": true,
        "has_embed": false
      },
      {
        "type": "paragraph",
        "tag": "p",
        "text_chars": 0,
        "text_preview": "",
        "has_image": false,
        "has_embed": false
      },
      {
        "type": "paragraph",
        "tag": "p",
        "text_chars": 44,
        "text_preview": "20 Minutes : une promesse éditoriale tenue !",
        "has_image": false,
        "has_embed": false
      },
      {
        "type": "paragraph",
        "tag": "p",
        "text_chars": 185,
        "text_preview": "Pour une très large majorité de Français s’informant avec 20 Minutes, la promess",
        "has_image": false,
        "has_embed": false
      },
      {
        "type": "paragraph",
        "tag": "p",
        "text_chars": 0,
        "text_preview": "",
        "has_image": false,
        "has_embed": false
      },
      {
        "type": "paragraph",
        "tag": "p",
        "text_chars": 45,
        "text_preview": "La marque la plus sympa de l’univers « info »",
        "has_image": false,
        "has_embed": false
      },
      {
        "type": "paragraph",
        "tag": "p",
        "text_chars": 246,
        "text_preview": "L’étude révèle un fort attachement à la marque 20 Minutes puisqu’elle est celle ",
        "has_image": false,
        "has_embed": false
      },
      {
        "type": "paragraph",
        "tag": "p",
        "text_chars": 239,
        "text_preview": "« Pour chacune de ces caractéristiques, vous nous indiquerez si vous êtes tout à",
        "has_image": false,
        "has_embed": false
      },
      {
        "type": "paragraph",
        "tag": "p",
        "text_chars": 0,
        "text_preview": "",
        "has_image": true,
        "has_embed": false
      },
      {
        "type": "paragraph",
        "tag": "p",
        "text_chars": 0,
        "text_preview": "",
        "has_image": false,
        "has_embed": false
      },
      {
        "type": "paragraph",
        "tag": "p",
        "text_chars": 58,
        "text_preview": "Un modèle qui plaît dans sa globalité, publicité incluse !",
        "has_image": false,
        "has_embed": false
      },
      {
        "type": "paragraph",
        "tag": "p",
        "text_chars": 411,
        "text_preview": "Chez 20 Minutes, la publicité est jugée mieux intégrée qu’ailleurs selon 63% des",
        "has_image": false,
        "has_embed": false
      },
      {
        "type": "paragraph",
        "tag": "p",
        "text_chars": 0,
        "text_preview": "",
        "has_image": false,
        "has_embed": false
      },
      {
        "type": "paragraph",
        "tag": "p",
        "text_chars": 52,
        "text_preview": ">> Retrouvez l’ensemble des résultats de cette étude",
        "has_image": false,
        "has_embed": false
      },
