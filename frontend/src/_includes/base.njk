<!doctype html>
<html lang="fr">
  <head>
    {% include "head.njk" %}
  </head>
  <body>
    <header class="site-header">
      <a class="site-title" href="/">{{ cms.site.name }}</a>
      <nav class="site-nav" aria-label="Sections">
        {% for postType in cms.postTypes %}
          <a href="/{{ postType | postTypeSlug }}/">{{ postType | postTypeSlug }}</a>
        {% endfor %}
      </nav>
    </header>
    <main class="site-main">{{ content | safe }}</main>
  </body>
</html>
